# =============================================================================
# Omnichain Asset Bridge — Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values.
# DO NOT commit your actual .env file to version control.
# =============================================================================

# Private key for an account funded on both local chains.
# Used for contract deployment and relayer transaction signing.
# This is the well-known Hardhat/Anvil test account #0 — safe for local development only.
DEPLOYER_PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80

# RPC URLs for the two local blockchain nodes
# When running outside Docker, use localhost addresses.
CHAIN_A_RPC_URL=http://127.0.0.1:8545
CHAIN_B_RPC_URL=http://127.0.0.1:9545

# Number of block confirmations the relayer waits before processing an event.
# Higher values increase security but add latency.
CONFIRMATION_DEPTH=3

# Path for the relayer's SQLite persistence database.
# This stores processed nonces and last-seen block numbers for crash recovery.
DB_PATH=./data/bridge.db

# ---- Chain IDs (must match the blockchain node configuration) ----
CHAIN_A_ID=1111
CHAIN_B_ID=2222

# ---- Addresses (auto-populated by deployment scripts) ----
# You can also set these manually if deploying outside Docker.
VAULT_TOKEN_ADDRESS=
BRIDGE_LOCK_ADDRESS=
GOVERNANCE_EMERGENCY_ADDRESS=
WRAPPED_VAULT_TOKEN_ADDRESS=
BRIDGE_MINT_ADDRESS=
GOVERNANCE_VOTING_ADDRESS=

# ---- Optional: Gas settings ----
# MAX_FEE_PER_GAS=50000000000
# MAX_PRIORITY_FEE_PER_GAS=1500000000

# ---- Logging ----
LOG_LEVEL=info
