{
  "name": "omni-chain-asset-bridge",
  "version": "1.0.0",
  "description": "Local Omnichain Asset Bridge with Governance Recovery System",
  "scripts": {
    "compile": "npx hardhat compile",
    "test": "npx hardhat test",
    "test:unit": "npx hardhat test tests/unit/*.test.js",
    "test:integration": "npx hardhat test tests/integration/*.test.js",
    "deploy:chainA": "npx hardhat run scripts/deployChainA.js --network chainA",
    "deploy:chainB": "npx hardhat run scripts/deployChainB.js --network chainB",
    "node:chainA": "npx hardhat node --port 8545",
    "node:chainB": "npx hardhat node --port 9545",
    "relayer": "node relayer/src/index.js",
    "lint": "npx solhint 'contracts/**/*.sol'"
  },
  "dependencies": {
    "@openzeppelin/contracts": "^5.0.2",
    "ethers": "^6.11.1"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-chai-matchers": "^2.0.6",
    "@nomicfoundation/hardhat-ethers": "^3.0.5",
    "@nomicfoundation/hardhat-network-helpers": "^1.0.10",
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "@nomicfoundation/hardhat-verify": "^2.0.7",
    "@typechain/ethers-v6": "^0.5.1",
    "@typechain/hardhat": "^9.1.0",
    "chai": "^4.4.1",
    "dotenv": "^16.4.5",
    "hardhat": "^2.22.3",
    "hardhat-gas-reporter": "^1.0.10",
    "solhint": "^5.0.1",
    "solidity-coverage": "^0.8.12",
    "typechain": "^8.3.2"
  }
}
